# ==========================================
# CONFIGURACIÓN DE SUPABASE (PLANTILLA)
# ==========================================

# URL de tu proyecto de Supabase (se obtiene en: Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Clave pública anónima (se obtiene en: Project Settings > API > anon public)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Clave de rol de servicio (se obtiene en: Project Settings > API > service_role)
# ¡NUNCA la expongas en el cliente/navegador!
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ==========================================
# CONEXIÓN DIRECTA A POSTGRESQL
# ==========================================

# Cadena de conexión URI para la base de datos (se obtiene en: Project Settings > Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# ==========================================
# PREFIJOS COMPATIBLES
# ==========================================

# Si usas Next.js o Vercel Serverless estándar
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Si usas Vite
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
